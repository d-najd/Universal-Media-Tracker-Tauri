{
	"name": "create-tauri-react",
	"version": "0.0.1",
	"description": "",
	"type": "module",
	"scripts": {
		"setupImportMap": "node vendor/getPackages.ts",
		"buildPlugins": "rimraf src/app/plugins/js && node plugins/esbuild.config.js",
		"dev": "npm-run-all buildPlugins && vite",
		"desktop": "npm-run-all buildPlugins && tauri dev",
		"android": "npm-run-all buildPlugins tauri android dev",
		"build": "npm-run-all buildPlugins && tsc && vite build",
		"preview": "npm-run-all buildPlugins && vite preview",
		"tauri": "npm-run-all buildPlugins && tauri",
		"prepare": "husky",
		"lint": "eslint . --report-unused-disable-directives --max-warnings 0",
		"format": "prettier --write ."
	},
	"lint-staged": {
		"**/*": "prettier --write --ignore-unknown"
	},
	"dependencies": {
		"@d-najd/universal-media-tracker-sdk": "^0.3.12",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@tailwindcss/vite": "^4.1.17",
		"@tauri-apps/api": "^2.9.1",
		"@tauri-apps/plugin-fs": "^2.4.5",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-shell": "^2.3.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"idb": "^8.0.3",
		"immer": "^11.1.4",
		"lucide-react": "^0.563.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"react-error-boundary": "^6.0.0",
		"react-hook-form": "^7.68.0",
		"react-router": "^7.10.1",
		"tailwind-merge": "^3.4.0",
		"tailwindcss-animate": "^1.0.7",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@tauri-apps/cli": "^2.9.5",
		"@types/jsdom": "^28.0.1",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"esbuild": "^0.27.4",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react": "^7.37.5",
		"globals": "^17.3.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.1",
		"lint-staged": "^16.2.7",
		"npm-run-all": "^4.1.5",
		"prettier": "3.8.1",
		"rimraf": "^6.1.3",
		"strip-json-comments": "^5.0.3",
		"tailwindcss": "^4.1.17",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"vite": "^7.2.6"
	}
